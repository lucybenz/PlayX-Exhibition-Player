{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Debug APK",
            "type": "shell",
            "command": "${workspaceFolder}/gradlew.bat",
            "args": ["assembleDebug"],
            "group": "build",
            "problemMatcher": ["$gradle"],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        },
        {
            "label": "Build & Run on MuMu",
            "type": "shell",
            "command": "cmd",
            "args": [
                "/c",
                "adb connect 127.0.0.1:7555 && ${workspaceFolder}/gradlew.bat assembleDebug && adb install -r ${workspaceFolder}/app\\build\\outputs\\apk\\debug\\app-debug.apk && adb shell am start -n com.example.playx/.MainActivity"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            }
        }
    ]
}
